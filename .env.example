# === Microsoft Entra ID SSO (required in production) ===
ENTRA_TENANT_ID=your-azure-ad-tenant-uuid
ENTRA_CLIENT_ID=your-app-registration-client-id
ENTRA_CLIENT_SECRET=your-app-registration-client-secret

# === SSO Email Handoff (optional) ===
# BOOKCLUB_SSO_LOGIN_URL=https://example.com/sso/login
# BOOKCLUB_SSO_SHARED_SECRET=
# BOOKCLUB_SSO_MAX_AGE_SECONDS=300
# BOOKCLUB_SSO_EMAIL_HEADERS=X-SSO-Email

# === Aladin API (book search) ===
# ALADIN_TTB_KEY=your-aladin-ttb-key

# === Rails / Puma ===
# PORT=3000
# RAILS_MAX_THREADS=3
# RAILS_LOG_LEVEL=info
# PIDFILE=tmp/pids/server.pid
# SOLID_QUEUE_IN_PUMA=true

# === Seed defaults ===
# BOOKCLUB_ADMIN_EMAIL=admin@edwards-bookclub.local
# BOOKCLUB_ADMIN_PASSWORD=changeme123!
