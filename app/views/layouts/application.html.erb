<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Edwards Bookclub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Edwards Bookclub">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <%= link_to "Edwards Bookclub", authenticated? ? root_path : new_session_path, class: "brand" %>

        <% if authenticated? %>
          <nav class="topbar-nav">
            <%= link_to "Home", root_path, class: "secondary" %>
            <%= link_to "Reports", reports_path, class: "secondary" %>
            <%= link_to "Books", books_path, class: "secondary" %>
            <%= link_to "Meetups", meetings_path, class: "secondary" %>
            <% if can_manage_members? %>
              <%= link_to "Members", admin_members_path, class: "secondary" %>
            <% end %>
            <% if can_manage_club? %>
              <%= link_to "Admin", admin_dashboard_path, class: "secondary" %>
              <%= link_to "Settings", admin_fiscal_periods_path, class: "secondary" %>
            <% else %>
              <%= link_to "My Portal", member_root_path, class: "secondary" %>
              <%= link_to "My Requests", member_book_requests_path, class: "secondary" %>
            <% end %>
            <span><%= current_user.email %></span>
            <%= button_to "Sign out", destroy_session_path, method: :delete, form: { data: { turbo: false } }, class: "secondary" %>
          </nav>
        <% end %>
      </div>
    </header>

    <% flash.each do |type, message| %>
      <div class="flash flash-<%= type %>"><%= message %></div>
    <% end %>

    <div class="shell">
      <%= yield %>
    </div>
  </body>
</html>
