<main>
  <h1>Sign in</h1>

  <%= form_with url: "/auth/entra_id", method: :post do |form| %>
    <%= form.submit "Sign in with Microsoft" %>
  <% end %>

  <hr>

  <details>
    <summary>Local sign-in (admin fallback)</summary>
    <p>Use the local admin seed or an imported user account.</p>

    <%= form_with url: session_path, method: :post do |form| %>
      <div>
        <%= form.label :email %>
        <%= form.email_field :email, required: true, autofocus: true, autocomplete: "username" %>
      </div>

      <div>
        <%= form.label :password %>
        <%= form.password_field :password, required: true, autocomplete: "current-password" %>
      </div>

      <div>
        <%= form.submit "Sign in" %>
      </div>
    <% end %>
  </details>
</main>
