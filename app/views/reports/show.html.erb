<section class="report-portal" style="display: grid; grid-template-columns: 260px 1fr; gap: 1.5rem; align-items: start;">
  <aside class="panel stack" style="position: sticky; top: 1rem;">
    <h2 style="font-size: 1.1rem; margin-bottom: 0.25rem;">Reports</h2>
    <p class="muted" style="font-size: 0.8rem; margin-bottom: 1rem;"><%= @dashboard.month_label %></p>

    <%= form_with url: reports_path, method: :get, local: true do |form| %>
      <div class="field-stack" style="margin-bottom: 0.75rem;">
        <%= form.label :fiscal_period_id, "Fiscal period", style: "font-size: 0.8rem;" %>
        <%= form.select :fiscal_period_id, options_for_select([["Active/default", ""]] + @fiscal_period_options.map { |period| [period.name, period.id] }, @filters[:fiscal_period_id]), {}, style: "font-size: 0.85rem;" %>
      </div>

      <div class="field-stack" style="margin-bottom: 0.75rem;">
        <%= form.label :month, "Month", style: "font-size: 0.8rem;" %>
        <%= form.month_field :month, value: @filters[:month], style: "font-size: 0.85rem;" %>
      </div>

      <div style="display: flex; gap: 0.5rem; margin-bottom: 0.75rem;">
        <%= form.submit "Apply", style: "font-size: 0.8rem; padding: 0.35rem 0.75rem;" %>
        <%= link_to "Reset", reports_path, class: "button-link secondary", style: "font-size: 0.8rem; padding: 0.35rem 0.75rem;" %>
      </div>
    <% end %>

    <%= form_with url: reports_docx_path, method: :post, local: true do |f| %>
      <%= f.hidden_field :fiscal_period_id, value: @filters[:fiscal_period_id] %>
      <%= f.hidden_field :month, value: @filters[:month] %>
      <%= f.submit "Download DOCX", class: "button-link secondary", style: "width: 100%; font-size: 0.85rem;" %>
    <% end %>

    <hr style="margin: 1rem 0; border: none; border-top: 1px solid var(--border, #ddd);">

    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
      <% if can_manage_club? %>
        <%= link_to "Open workspace", admin_dashboard_path, class: "button-link secondary", style: "font-size: 0.8rem; text-align: center;" %>
        <%= link_to "Members", admin_members_path, class: "button-link secondary", style: "font-size: 0.8rem; text-align: center;" %>
      <% else %>
        <%= link_to "My Portal", member_root_path, class: "button-link secondary", style: "font-size: 0.8rem; text-align: center;" %>
        <%= link_to "My Requests", member_book_requests_path, class: "button-link secondary", style: "font-size: 0.8rem; text-align: center;" %>
      <% end %>
    </div>
  </aside>

  <div>
  <section class="metrics report-kpis">
    <article class="metric-card">
      <span class="muted">Fiscal period</span>
      <strong><%= @dashboard.fiscal_period&.name || "None" %></strong>
    </article>
    <article class="metric-card">
      <span class="muted">Reserve balance</span>
      <strong><%= number_to_currency(@dashboard.reserve_snapshot.balance, unit: "₩", precision: 0) %></strong>
    </article>
    <article class="metric-card">
      <span class="muted">Attendance reserve</span>
      <strong><%= number_to_currency(@dashboard.reserve_snapshot.attendance_reserve_total, unit: "₩", precision: 0) %></strong>
    </article>
    <article class="metric-card">
      <span class="muted">Book orders</span>
      <strong><%= number_to_currency(@dashboard.reserve_snapshot.purchased_book_total, unit: "₩", precision: 0) %></strong>
    </article>
    <article class="metric-card">
      <span class="muted">Additional payments</span>
      <strong><%= number_to_currency(@dashboard.reserve_snapshot.additional_payment_total, unit: "₩", precision: 0) %></strong>
    </article>
  </section>

  <section class="report-portal-grid">
    <article class="panel stack report-portal-feature">
      <div class="section-title">
        <div>
          <h2>Reserve leaderboard</h2>
          <p class="muted">Attendance reserve, book spend, and additional payments rolled up by member.</p>
        </div>
        <p class="muted"><%= @dashboard.fiscal_period&.name || "No period" %></p>
      </div>

      <div class="detail-grid reserve-grid">
        <div class="stack">
          <div class="section-title">
            <h3>Attendance leaders</h3>
            <span class="muted">Top members by attendance count</span>
          </div>
          <div class="bar-list attendance-leaderboard">
            <% top_attendance = [@dashboard.attendance_leaderboard.map(&:attendance_count).max.to_i, 1].max %>
            <% @dashboard.attendance_leaderboard.each do |row| %>
              <div class="bar-row">
                <div class="section-title compact">
                  <span><%= row.member.display_name %></span>
                  <span class="location-pill tone-<%= row.tone %>"><%= row.member.location.presence || "미정" %></span>
                </div>
                <div class="bar-track attendance-track">
                  <div class="bar-fill tone-<%= row.tone %>" style="width: <%= ((row.attendance_count.to_f / top_attendance) * 100).round(1) %>%"></div>
                  <strong><%= row.attendance_count %></strong>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div class="stack">
          <div class="section-title">
            <h3>Member reserve standings</h3>
            <span class="muted">Balance = reserve - books + additional</span>
          </div>
          <% if @dashboard.reserve_leaderboard.any? %>
            <div class="report-table-wrap">
              <table class="data-table report-table">
                <thead>
                  <tr>
                    <th>Member</th>
                    <th>Balance</th>
                    <th>Reserve</th>
                    <th>Books</th>
                    <th>Additional</th>
                  </tr>
                </thead>
                <tbody>
                  <% @dashboard.reserve_leaderboard.each do |row| %>
                    <tr>
                      <td>
                        <div class="member-cell">
                          <strong><%= row.member.display_name %></strong>
                          <span class="location-pill tone-<%= row.tone %>"><%= row.member.location.presence || "미정" %></span>
                        </div>
                      </td>
                      <td><strong><%= number_to_currency(row.balance, unit: "₩", precision: 0) %></strong></td>
                      <td><%= number_to_currency(row.attendance_reserve, unit: "₩", precision: 0) %></td>
                      <td><%= number_to_currency(row.book_total, unit: "₩", precision: 0) %></td>
                      <td><%= number_to_currency(row.additional_payment_total, unit: "₩", precision: 0) %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="empty-state">
              <h3>No reserve activity yet.</h3>
              <p>Reserve standings will appear after attendance and book activity are imported.</p>
            </div>
          <% end %>
        </div>
      </div>
    </article>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: start;">
    <article class="panel stack">
      <div class="section-title">
        <div>
          <h2>Attendance report</h2>
          <p class="muted">Monthly trend and breakdown.</p>
        </div>
        <p class="muted"><%= @dashboard.month_label %></p>
      </div>

      <div class="metrics inline-metrics report-inline-metrics">
        <article class="metric-card">
          <span class="muted">Total</span>
          <strong><%= @dashboard.location_breakdown.sum(&:count) %></strong>
        </article>
        <% @dashboard.location_breakdown.each do |point| %>
          <article class="metric-card location-metric tone-<%= point.tone %>">
            <span class="muted"><%= point.label %></span>
            <strong><%= point.count %></strong>
          </article>
        <% end %>
      </div>

      <div class="stack">
        <div class="section-title">
          <h3>Monthly attendance by location</h3>
          <span class="muted">Stacked horizontal bars by meetup location</span>
        </div>
        <% max_monthly_count = [@dashboard.monthly_attendance.map(&:count).max.to_i, 1].max %>
        <div class="bar-list" style="gap: 0.5rem;">
          <% @dashboard.monthly_attendance.each do |point| %>
            <% next if point.count.zero? %>
            <div class="bar-row">
              <div style="min-width: 60px; font-size: 0.8rem; color: var(--muted-text, #888);"><%= point.label %></div>
              <div class="bar-track" style="flex: 1; display: flex; height: 24px; border-radius: 4px; overflow: hidden; background: var(--muted-bg, #eee);">
                <% @dashboard.location_legend.each do |location_label| %>
                  <% segment_count = point.location_counts.fetch(location_label, 0) %>
                  <% next if segment_count.zero? %>
                  <div class="bar-fill tone-<%= Admin::DashboardSnapshot::LOCATION_TONES.fetch(location_label, "neutral") %>" style="width: <%= ((segment_count.to_f / max_monthly_count) * 100).round(1) %>%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; color: #fff; font-weight: 600;">
                    <%= segment_count %>
                  </div>
                <% end %>
              </div>
              <strong style="min-width: 28px; text-align: right; font-size: 0.85rem;"><%= point.count %></strong>
            </div>
          <% end %>
        </div>
        <div class="legend-row" style="margin-top: 0.5rem;">
          <% @dashboard.location_legend.each do |location_label| %>
            <span class="legend-item">
              <span class="legend-swatch tone-<%= Admin::DashboardSnapshot::LOCATION_TONES.fetch(location_label, "neutral") %>"></span>
              <%= location_label %>
            </span>
          <% end %>
        </div>
      </div>

      <div class="stack" style="margin-top: 1.5rem;">
        <div class="section-title">
          <h3>Selected month breakdown</h3>
          <span class="muted"><%= @dashboard.month_label %></span>
        </div>
        <% if @dashboard.location_breakdown.any? %>
          <div class="bar-list">
            <% @dashboard.location_breakdown.each do |point| %>
              <div class="bar-row">
                <div class="section-title compact">
                  <span class="location-pill tone-<%= point.tone %>"><%= point.label %></span>
                  <strong><%= point.count %></strong>
                </div>
                <div class="bar-track">
                  <div class="bar-fill tone-<%= point.tone %>" style="width: <%= (point.ratio * 100).round(1) %>%"></div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="empty-state">
            <h3>No attendance data for this month.</h3>
            <p>Choose another month to inspect meetup activity.</p>
          </div>
        <% end %>
      </div>
    </article>

    <article class="panel report-panel stack">
      <div class="section-title">
        <h2>Meetup register</h2>
        <span class="muted"><%= pluralize(@dashboard.meeting_digests.size, "meetup") %></span>
      </div>

      <% if @dashboard.meeting_digests.any? %>
        <div class="stack" style="gap: 0.5rem;">
          <% @dashboard.meeting_digests.each do |digest| %>
            <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0.75rem; border: 1px solid var(--border, #ddd); border-radius: 6px;">
              <div style="flex: 1; min-width: 0;">
                <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                  <strong style="font-size: 0.85rem;"><%= digest.meeting.title %></strong>
                  <span class="location-pill tone-<%= digest.tone %>" style="font-size: 0.7rem;"><%= digest.meeting.location.presence || "미정" %></span>
                </div>
                <p class="muted" style="font-size: 0.75rem; margin: 0;"><%= l(digest.meeting.meeting_at.to_date, format: :long) %></p>
              </div>
              <div style="display: flex; gap: 0.75rem; text-align: center; flex-shrink: 0;">
                <div>
                  <span class="muted" style="font-size: 0.65rem; display: block;">Attendees</span>
                  <strong style="font-size: 0.9rem;"><%= digest.attendance_count %></strong>
                </div>
                <div>
                  <span class="muted" style="font-size: 0.65rem; display: block;">Photos</span>
                  <strong style="font-size: 0.9rem;"><%= digest.photos.size %></strong>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <h3>No meetups for this month.</h3>
          <p>The meetup register will populate after attendance records exist in the selected month.</p>
        </div>
      <% end %>
    </article>
    </div>

    <article class="panel report-panel stack">
      <div class="section-title">
        <h2>Photo wall</h2>
        <span class="muted"><%= @dashboard.month_label %></span>
      </div>
      <% photo_count = @dashboard.meeting_digests.sum { |digest| digest.photos.size } %>
      <% if photo_count.positive? %>
        <div class="photo-wall dense-photo-wall">
          <% @dashboard.meeting_digests.each do |digest| %>
            <% digest.photos.each do |photo| %>
              <figure class="photo-card">
                <%= image_tag(photo.source_url.presence || photo.file_path, alt: "#{digest.meeting.title} photo") %>
                <figcaption>
                  <strong><%= digest.meeting.title %></strong>
                  <span><%= digest.meeting.location.presence || "미정" %> · <%= l(digest.meeting.meeting_at.to_date, format: :long) %></span>
                </figcaption>
              </figure>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <h3>No photos for this month.</h3>
          <p>Photos added to meetups will appear here.</p>
        </div>
      <% end %>
    </article>

    <section class="panel stack reviews-panel report-full-span">
      <div class="section-title">
        <div>
          <h2>Meetup reviews</h2>
          <p class="muted">Readable monthly review notes instead of dense table-cell text.</p>
        </div>
        <p class="muted"><%= @dashboard.month_label %></p>
      </div>

      <% if @dashboard.review_highlights.any? %>
        <div class="review-grid">
          <% @dashboard.review_highlights.each do |digest| %>
            <article class="review-card">
              <div class="section-title compact">
                <div>
                  <h3><%= digest.meeting.title %></h3>
                  <p class="muted"><%= l(digest.meeting.meeting_at.to_date, format: :long) %></p>
                </div>
                <span class="location-pill tone-<%= digest.tone %>"><%= digest.meeting.location.presence || "미정" %></span>
              </div>
              <p><%= simple_format(digest.meeting.review) %></p>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <h3>No meetup reviews for this month.</h3>
          <p>Reviews will show here when a meetup note is saved on the meetup record.</p>
        </div>
      <% end %>
    </section>
  </section>
  </div>
</section>
