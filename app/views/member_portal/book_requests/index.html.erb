<section class="hero">
  <p class="eyebrow">Member Portal</p>
  <h1>My book requests</h1>
  <p class="hero-copy">Track your own request history and update the submission details you control.</p>
</section>

<section class="panel stack">
  <div class="section-title">
    <div>
      <h2>Your requests</h2>
      <p class="muted">Admin-only lifecycle fields stay visible but are not editable here.</p>
    </div>
    <%= link_to "New request", new_member_book_request_path, class: "button-link" %>
  </div>

  <% if @book_requests.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Book</th>
          <th>Status</th>
          <th>Requested</th>
          <th>Price</th>
          <th>Additional</th>
        </tr>
      </thead>
      <tbody>
        <% @book_requests.each do |request| %>
          <tr>
            <td>
              <div class="book-table-cell">
                <% if request.remote_cover_url.present? %>
                  <%= image_tag request.remote_cover_url, alt: "#{request.title} cover", class: "book-table-cover" %>
                <% end %>
                <div>
                  <strong><%= link_to request.title, member_book_request_path(request) %></strong>
                  <div class="muted"><%= [request.author, request.publisher].compact.reject(&:blank?).join(" · ").presence || "No metadata" %></div>
                </div>
              </div>
            </td>
            <td><span class="pill"><%= request.request_status.presence || "Requested" %></span></td>
            <td><%= request.requested_on&.iso8601 || "Not set" %></td>
            <td><%= request.price ? number_to_currency(request.price, unit: "KRW ", precision: 0) : "Pending" %></td>
            <td><%= request.additional_payment ? number_to_currency(request.additional_payment, unit: "KRW ", precision: 0) : "None" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <h3>No book requests yet.</h3>
      <p>Submit a request to start your own queue.</p>
    </div>
  <% end %>
</section>
