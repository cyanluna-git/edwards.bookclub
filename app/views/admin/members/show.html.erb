<section class="hero">
  <p class="eyebrow">Member Detail</p>
  <h1><%= @member.english_name %></h1>
  <p class="hero-copy">
    Review linked operational context before editing or changing active status.
  </p>
</section>

<section class="detail-grid">
  <article class="panel">
    <div class="results-header">
      <div>
        <h2>Profile</h2>
        <p class="muted"><%= @member.korean_name.presence || "No Korean name recorded" %></p>
      </div>
      <span class="pill <%= @member.active? ? "active" : "inactive" %>"><%= @member.active? ? "Active" : "Inactive" %></span>
    </div>

    <div class="pill-row">
      <span class="pill"><%= @member.member_role %></span>
      <span class="pill"><%= @member.location.presence || "No location" %></span>
      <% if @member.leader_role? %>
        <span class="pill">Leader</span>
      <% end %>
    </div>

    <div class="meta-list">
      <div><span>Email</span><span><%= @member.email.presence || "Not set" %></span></div>
      <div><span>Department</span><span><%= @member.department.presence || "Not set" %></span></div>
      <div><span>Joined on</span><span><%= @member.joined_on&.iso8601 || "Not set" %></span></div>
      <div><span>Linked user</span><span><%= @member.user&.email || "None" %></span></div>
      <div><span>Source</span><span><%= [@member.source_system, @member.source_key].compact.join(":").presence || "Manual" %></span></div>
    </div>

    <% if @member.bio.present? %>
      <div class="field-stack">
        <label>Bio</label>
        <div class="panel"><%= simple_format(@member.bio) %></div>
      </div>
    <% end %>

    <div class="field-stack">
      <label>Current office assignments</label>
      <div class="panel">
        <% current_assignments = @member.office_labels_on(Date.current) %>
        <% if current_assignments.any? %>
          <div class="pill-row">
            <% current_assignments.each do |label| %>
              <span class="pill"><%= label %></span>
            <% end %>
          </div>
        <% else %>
          <p class="muted">No active office assignments today.</p>
        <% end %>
        <div class="button-row" style="margin-top: 0.75rem;">
          <%= link_to "Open Office Assignments", admin_office_assignments_path(member_id: @member.id), class: "button-link secondary" %>
          <%= link_to "New assignment", new_admin_office_assignment_path(member_id: @member.id), class: "button-link secondary" %>
        </div>
      </div>
    </div>
  </article>

  <aside class="panel">
    <h2>Operational context</h2>
    <div class="stat-list">
      <div><span>Attendance rows</span><strong><%= @member.meeting_attendances.count %></strong></div>
      <div><span>Book requests</span><strong><%= @member.book_requests.count %></strong></div>
      <div><span>Meetups attended</span><strong><%= @member.meetings.distinct.count %></strong></div>
    </div>

    <div class="field-stack">
      <label>Recent book requests</label>
      <div class="panel">
        <% if @member.book_requests.any? %>
          <ul>
            <% @member.book_requests.order(requested_on: :desc, created_at: :desc).limit(5).each do |request| %>
              <li><%= request.title %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="muted">No linked requests.</p>
        <% end %>
      </div>
    </div>

    <div class="field-stack">
      <label>Recent meetups</label>
      <div class="panel">
        <% if @member.meetings.any? %>
          <ul>
            <% @member.meetings.distinct.order(meeting_at: :desc).limit(5).each do |meeting| %>
              <li><%= meeting.title %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="muted">No attendance history yet.</p>
        <% end %>
      </div>
    </div>

    <div class="button-row">
      <%= link_to "Edit member", edit_admin_member_path(@member), class: "button-link" %>
      <% if @member.active? %>
        <%= button_to "Mark inactive", deactivate_admin_member_path(@member), method: :patch, class: "danger" %>
      <% else %>
        <%= button_to "Reactivate", reactivate_admin_member_path(@member), method: :patch, class: "warn" %>
      <% end %>
      <%= link_to "Back to members", admin_members_path, class: "button-link secondary" %>
    </div>
  </aside>
</section>

<section class="panel stack">
  <div class="section-title">
    <div>
      <h2>Access control</h2>
      <p class="muted">Manage sign-in access here. Explicit `admin` stays separate from office-based chairperson access.</p>
    </div>
  </div>

  <div class="detail-grid">
    <article class="panel">
      <div class="meta-list">
        <div><span>Linked access</span><span><%= @member.user&.email || "None" %></span></div>
        <div><span>App role</span><span><%= @member.user&.role || "None" %></span></div>
        <div><span>Effective access</span><span><%= @member.user&.management_access_label || "No account" %></span></div>
      </div>
    </article>

    <article class="panel">
      <%= form_with url: admin_member_access_path(@member), method: @member.user.present? ? :patch : :post, scope: :user_access, local: true do |form| %>
        <div class="detail-grid">
          <div>
            <div class="field-stack">
              <%= form.label :email, "Login email" %>
              <%= form.email_field :email, value: @member.user&.email || @member.email, required: true %>
            </div>

            <div class="field-stack">
              <%= form.label :role, "App role" %>
              <%= form.select :role, options_for_select([["Member", "member"], ["Admin", "admin"]], @member.user&.role || "member") %>
            </div>
          </div>

          <div>
            <div class="field-stack">
              <%= form.label :password, @member.user.present? ? "New password" : "Temporary password" %>
              <%= form.password_field :password, autocomplete: "new-password" %>
            </div>

            <div class="field-stack">
              <%= form.label :password_confirmation, "Confirm password" %>
              <%= form.password_field :password_confirmation, autocomplete: "new-password" %>
            </div>
          </div>
        </div>

        <div class="button-row">
          <%= form.submit(@member.user.present? ? "Update access" : "Create access") %>
        </div>
      <% end %>
      <% if @member.user.present? %>
        <div class="button-row">
          <%= button_to "Remove access", admin_member_access_path(@member), method: :delete, class: "danger" %>
        </div>
      <% end %>
    </article>
  </div>
</section>
