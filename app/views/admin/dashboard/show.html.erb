<section class="dashboard-layout">
  <aside class="dashboard-sidebar">
    <section class="hero dashboard-hero">
      <p class="eyebrow"><%= can_manage_club? ? "Admin Dashboard" : "Club Reports" %></p>
      <h1>Book club reporting room</h1>
      <p class="hero-copy">
        PBIX-style reserve standings, month-by-month attendance, meetup photos, and readable review notes from the Rails data model.
      </p>
    </section>

    <section class="panel stack dashboard-filter-panel">
      <div class="section-title sidebar-title">
        <div>
          <h2>Report scope</h2>
          <p class="muted">Reserve figures stay fiscal-period scoped. Attendance records, photos, and reviews follow the selected month.</p>
        </div>
      </div>

      <div class="button-row sidebar-actions">
        <% if can_manage_club? %>
          <%= link_to "Members", admin_members_path, class: "button-link secondary" %>
          <%= link_to "Meetups", admin_meetings_path, class: "button-link secondary" %>
          <%= link_to "Books", admin_book_requests_path, class: "button-link secondary" %>
          <%= link_to "Settings", admin_fiscal_periods_path, class: "button-link secondary" %>
        <% else %>
          <%= link_to "My Portal", member_root_path, class: "button-link secondary" %>
          <%= link_to "My Requests", member_book_requests_path, class: "button-link secondary" %>
        <% end %>
      </div>

      <%= form_with url: @dashboard_path, method: :get, local: true do |form| %>
        <div class="field-stack">
          <%= form.label :fiscal_period_id, "Fiscal period" %>
          <%= form.select :fiscal_period_id, options_for_select([["Active/default", ""]] + @fiscal_period_options.map { |period| [period.name, period.id] }, @filters[:fiscal_period_id]) %>
        </div>
        <div class="field-stack">
          <%= form.label :month, "Attendance month" %>
          <%= form.month_field :month, value: @filters[:month] %>
        </div>
        <div class="button-row">
          <%= form.submit "Apply filters" %>
          <%= link_to "Reset", @dashboard_path, class: "button-link secondary" %>
        </div>
      <% end %>
    </section>

    <section class="metrics dashboard-metrics dashboard-sidebar-metrics">
      <article class="metric-card">
        <span class="muted">Fiscal period</span>
        <strong><%= @dashboard.fiscal_period&.name || "None" %></strong>
      </article>
      <article class="metric-card">
        <span class="muted">Reserve balance</span>
        <strong><%= number_to_currency(@dashboard.reserve_snapshot.balance, unit: "₩", precision: 0) %></strong>
      </article>
      <article class="metric-card">
        <span class="muted">Attendance reserve</span>
        <strong><%= number_to_currency(@dashboard.reserve_snapshot.attendance_reserve_total, unit: "₩", precision: 0) %></strong>
      </article>
      <article class="metric-card">
        <span class="muted">Book orders</span>
        <strong><%= number_to_currency(@dashboard.reserve_snapshot.purchased_book_total, unit: "₩", precision: 0) %></strong>
      </article>
      <article class="metric-card">
        <span class="muted">Additional payments</span>
        <strong><%= number_to_currency(@dashboard.reserve_snapshot.additional_payment_total, unit: "₩", precision: 0) %></strong>
      </article>
    </section>
  </aside>

  <main class="dashboard-main">
    <section class="detail-grid dashboard-report-grid">
      <article class="panel stack reserve-composition">
    <div class="section-title">
      <div>
        <h2>Reserve leaderboard</h2>
        <p class="muted">Attendance reserve, book spend, and additional payments rolled up by member.</p>
      </div>
      <p class="muted"><%= @dashboard.fiscal_period&.name || "No period" %></p>
    </div>

    <div class="detail-grid reserve-grid">
      <div class="stack">
        <div class="section-title">
          <h3>Attendance leaders</h3>
          <span class="muted">Top members by attendance count</span>
        </div>
        <div class="bar-list attendance-leaderboard">
          <% top_attendance = [@dashboard.attendance_leaderboard.map(&:attendance_count).max.to_i, 1].max %>
          <% @dashboard.attendance_leaderboard.each do |row| %>
            <div class="bar-row">
              <div class="section-title compact">
                <span><%= row.member.display_name %></span>
                <span class="location-pill tone-<%= row.tone %>"><%= row.member.location.presence || "미정" %></span>
              </div>
              <div class="bar-track attendance-track">
                <div class="bar-fill tone-<%= row.tone %>" style="width: <%= ((row.attendance_count.to_f / top_attendance) * 100).round(1) %>%"></div>
                <strong><%= row.attendance_count %></strong>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="stack">
        <div class="section-title">
          <h3>Member reserve standings</h3>
          <span class="muted">Balance = reserve - books + additional</span>
        </div>
        <% if @dashboard.reserve_leaderboard.any? %>
          <div class="report-table-wrap">
            <table class="data-table report-table">
              <thead>
                <tr>
                  <th>Member</th>
                  <th>Balance</th>
                  <th>Reserve</th>
                  <th>Books</th>
                  <th>Additional</th>
                </tr>
              </thead>
              <tbody>
                <% @dashboard.reserve_leaderboard.each do |row| %>
                  <tr>
                    <td>
                      <div class="member-cell">
                        <strong><%= row.member.display_name %></strong>
                        <span class="location-pill tone-<%= row.tone %>"><%= row.member.location.presence || "미정" %></span>
                      </div>
                    </td>
                    <td><strong><%= number_to_currency(row.balance, unit: "₩", precision: 0) %></strong></td>
                    <td><%= number_to_currency(row.attendance_reserve, unit: "₩", precision: 0) %></td>
                    <td><%= number_to_currency(row.book_total, unit: "₩", precision: 0) %></td>
                    <td><%= number_to_currency(row.additional_payment_total, unit: "₩", precision: 0) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="empty-state">
            <h3>No reserve activity yet.</h3>
            <p>Reserve standings will appear after attendance and book activity are imported.</p>
          </div>
        <% end %>
      </div>
    </div>
      </article>
    </section>

    <section class="panel stack attendance-composition">
      <div class="section-title">
        <div>
          <h2>Attendance report</h2>
          <p class="muted">Monthly attendance trend, selected-month breakdown, meetup register, and photo digest laid out for widescreen reading.</p>
        </div>
        <p class="muted"><%= @dashboard.month_label %></p>
      </div>

  <div class="metrics inline-metrics">
    <article class="metric-card">
      <span class="muted">Selected month attendees</span>
      <strong><%= @dashboard.location_breakdown.sum(&:count) %></strong>
    </article>
    <% @dashboard.location_breakdown.each do |point| %>
      <article class="metric-card location-metric tone-<%= point.tone %>">
        <span class="muted"><%= point.label %></span>
        <strong><%= point.count %></strong>
      </article>
    <% end %>
  </div>

  <div class="detail-grid attendance-summary-grid">
    <div class="stack">
      <div class="section-title">
        <h3>Monthly attendance by location</h3>
        <span class="muted">Stacked by meetup location</span>
      </div>
      <% max_monthly_count = [@dashboard.monthly_attendance.map(&:count).max.to_i, 1].max %>
      <div class="attendance-trend-chart">
        <% @dashboard.monthly_attendance.each do |point| %>
          <div class="attendance-month">
            <div class="attendance-month-bar">
              <div class="attendance-month-stack" style="height: <%= ((point.count.to_f / max_monthly_count) * 100).round(1) %>%">
                <% @dashboard.location_legend.each do |location_label| %>
                  <% segment_count = point.location_counts.fetch(location_label, 0) %>
                  <% next if segment_count.zero? %>
                  <div class="attendance-month-segment tone-<%= Admin::DashboardSnapshot::LOCATION_TONES.fetch(location_label, "neutral") %>" style="height: <%= ((segment_count.to_f / point.count) * 100).round(1) %>%">
                    <span><%= segment_count %></span>
                  </div>
                <% end %>
              </div>
            </div>
            <span class="attendance-month-label"><%= point.label %></span>
          </div>
        <% end %>
      </div>
      <div class="legend-row">
        <% @dashboard.location_legend.each do |location_label| %>
          <span class="legend-item">
            <span class="legend-swatch tone-<%= Admin::DashboardSnapshot::LOCATION_TONES.fetch(location_label, "neutral") %>"></span>
            <%= location_label %>
          </span>
        <% end %>
      </div>
    </div>

    <div class="stack">
      <div class="section-title">
        <h3>Selected month breakdown</h3>
        <span class="muted"><%= @dashboard.month_label %></span>
      </div>
      <% if @dashboard.location_breakdown.any? %>
        <div class="bar-list">
          <% @dashboard.location_breakdown.each do |point| %>
            <div class="bar-row">
              <div class="section-title compact">
                <span class="location-pill tone-<%= point.tone %>"><%= point.label %></span>
                <strong><%= point.count %></strong>
              </div>
              <div class="bar-track">
                <div class="bar-fill tone-<%= point.tone %>" style="width: <%= (point.ratio * 100).round(1) %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <h3>No attendance data for this month.</h3>
          <p>Choose another month to inspect meetup activity.</p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="detail-grid register-grid">
    <div class="panel report-panel stack">
      <div class="section-title">
        <h3>Meetup register</h3>
        <span class="muted"><%= pluralize(@dashboard.meeting_digests.size, "meetup") %></span>
      </div>
      <% if @dashboard.meeting_digests.any? %>
        <div class="meeting-register-grid">
          <% @dashboard.meeting_digests.each do |digest| %>
            <article class="meeting-register-card">
              <div class="section-title compact">
                <div>
                  <h4>
                    <% if can_manage_club? %>
                      <%= link_to digest.meeting.title, admin_meeting_path(digest.meeting) %>
                    <% else %>
                      <%= digest.meeting.title %>
                    <% end %>
                  </h4>
                  <p class="muted"><%= l(digest.meeting.meeting_at.to_date, format: :long) %></p>
                </div>
                <span class="location-pill tone-<%= digest.tone %>"><%= digest.meeting.location.presence || "미정" %></span>
              </div>
              <div class="meeting-register-meta">
                <div>
                  <span class="muted">Attendees</span>
                  <strong><%= digest.attendance_count %></strong>
                </div>
                <div>
                  <span class="muted">Photos</span>
                  <strong><%= digest.photos.size %></strong>
                </div>
              </div>
              <div class="attendee-list attendee-list-grid">
                <% digest.attendees.each do |member| %>
                  <span><%= member.display_name %></span>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <h3>No meetups for this month.</h3>
          <p>The meetup register will populate after attendance records exist in the selected month.</p>
        </div>
      <% end %>
    </div>

    <div class="panel report-panel stack">
      <div class="section-title">
        <h3>Photo wall</h3>
        <span class="muted"><%= @dashboard.month_label %></span>
      </div>
      <% photo_count = @dashboard.meeting_digests.sum { |digest| digest.photos.size } %>
      <% if photo_count.positive? %>
        <div class="photo-wall">
          <% @dashboard.meeting_digests.each do |digest| %>
            <% digest.photos.each do |photo| %>
              <figure class="photo-card">
                <% if photo.image.attached? %>
                  <%= image_tag url_for(photo.image), alt: "#{digest.meeting.title} photo" %>
                <% elsif photo.source_url.present? || photo.file_path.present? %>
                  <%= image_tag(photo.source_url.presence || photo.file_path, alt: "#{digest.meeting.title} photo") %>
                <% end %>
                <figcaption>
                  <strong><%= digest.meeting.title %></strong>
                  <span><%= digest.meeting.location.presence || "미정" %> · <%= l(digest.meeting.meeting_at.to_date, format: :long) %></span>
                </figcaption>
              </figure>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <h3>No photos for this month.</h3>
          <p>Photos added to meetups will appear here.</p>
        </div>
      <% end %>
    </div>
  </div>
    </section>

    <section class="panel stack reviews-panel">
      <div class="section-title">
        <div>
          <h2>Meetup reviews</h2>
          <p class="muted">Readable monthly review notes instead of dense table-cell text.</p>
        </div>
        <p class="muted"><%= @dashboard.month_label %></p>
      </div>

      <% if @dashboard.review_highlights.any? %>
        <div class="review-grid">
          <% @dashboard.review_highlights.each do |digest| %>
            <article class="review-card">
              <div class="section-title compact">
                <div>
                  <h3><%= digest.meeting.title %></h3>
                  <p class="muted"><%= l(digest.meeting.meeting_at.to_date, format: :long) %></p>
                </div>
                <span class="location-pill tone-<%= digest.tone %>"><%= digest.meeting.location.presence || "미정" %></span>
              </div>
              <p><%= simple_format(digest.meeting.review) %></p>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state">
          <h3>No meetup reviews for this month.</h3>
          <p>Reviews will show here when a meetup note is saved on the meetup record.</p>
        </div>
      <% end %>
    </section>
  </main>
</section>
