<section class="hero">
  <p class="eyebrow">Book Request</p>
  <h1><%= @book_request.title %></h1>
  <p class="hero-copy">
    Maintain the spending and additional-payment fields that feed reserve balance calculations and later reporting.
  </p>
</section>

<section class="detail-grid">
  <article class="panel stack">
    <div class="section-title">
      <div>
        <h2>Request details</h2>
        <p class="muted"><%= @book_request.request_status.presence || "No status" %></p>
      </div>
      <div class="button-row">
        <%= link_to "Edit request", edit_admin_book_request_path(@book_request), class: "button-link" %>
        <%= link_to "Back to requests", admin_book_requests_path, class: "button-link secondary" %>
      </div>
    </div>

    <div class="meta-list">
      <div><span>Member</span><span><%= @book_request.member&.english_name || "Unlinked" %></span></div>
      <div><span>Fiscal period</span><span><%= @book_request.fiscal_period&.name || "None" %></span></div>
      <div><span>Requested on</span><span><%= @book_request.requested_on&.iso8601 || "Not set" %></span></div>
      <div><span>Author</span><span><%= @book_request.author.presence || "Not set" %></span></div>
      <div><span>Publisher</span><span><%= @book_request.publisher.presence || "Not set" %></span></div>
      <div><span>Rating</span><span><%= @book_request.rating.presence || "Not set" %></span></div>
      <div><span>Price</span><span><%= @book_request.price ? number_to_currency(@book_request.price, unit: "KRW ", precision: 0) : "Not set" %></span></div>
      <div><span>Additional payment</span><span><%= @book_request.additional_payment ? number_to_currency(@book_request.additional_payment, unit: "KRW ", precision: 0) : "Not set" %></span></div>
      <div><span>Net cash effect</span><span><%= number_to_currency(@book_request.net_cash_effect, unit: "KRW ", precision: 0) %></span></div>
    </div>

    <% if @book_request.comment.present? %>
      <div class="field-stack">
        <label>Comment</label>
        <div class="panel"><%= simple_format(@book_request.comment) %></div>
      </div>
    <% end %>
  </article>

  <aside class="panel stack">
    <h2>Links</h2>
    <ul class="list-clean">
      <li><%= @book_request.link_url.present? ? link_to(@book_request.link_url, @book_request.link_url) : "No purchase link" %></li>
      <li><%= @book_request.cover_url.present? ? link_to(@book_request.cover_url, @book_request.cover_url) : "No cover link" %></li>
    </ul>
  </aside>
</section>
