<% if meeting.errors.any? %>
  <div class="errors">
    <h3><%= pluralize(meeting.errors.count, "issue") %> blocked this save</h3>
    <ul>
      <% meeting.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [:admin, meeting], local: true, multipart: true do |form| %>
  <div class="detail-grid">
    <div>
      <div class="field-stack">
        <%= form.label :title %>
        <%= form.text_field :title, required: true %>
      </div>

      <div class="field-stack">
        <%= form.label :legacy_title, "Legacy title" %>
        <%= form.text_field :legacy_title %>
      </div>

      <div class="field-stack">
        <%= form.label :location %>
        <%= form.text_field :location %>
      </div>

      <div class="field-stack">
        <%= form.label :description %>
        <%= form.text_area :description %>
      </div>
    </div>

    <div>
      <div class="field-stack">
        <%= form.label :meeting_at, "Date and time" %>
        <%= form.datetime_local_field :meeting_at, value: meeting.meeting_at&.strftime("%Y-%m-%dT%H:%M"), required: true %>
      </div>

      <div class="field-stack">
        <%= form.label :fiscal_period_id, "Fiscal period" %>
        <%= form.select :fiscal_period_id, options_for_select(fiscal_period_options.map { |period| [period.name, period.id] }, meeting.fiscal_period_id), include_blank: "No fiscal period" %>
      </div>

      <div class="field-stack">
        <%= form.label :reserve_exempt_default, "Default reserve behavior" %>
        <%= form.select :reserve_exempt_default, options_for_select([["Reserve applies", false], ["Reserve exempt by default", true]], meeting.reserve_exempt_default) %>
      </div>

      <div class="field-stack">
        <%= form.label :review %>
        <%= form.text_area :review %>
      </div>
    </div>
  </div>

  <div class="field-stack">
    <label>Photos</label>
    <% if meeting.persisted? && meeting.meeting_photos.any? %>
      <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;">
        <% meeting.meeting_photos.each do |photo| %>
          <% if photo.image.attached? %>
            <%= image_tag url_for(photo.image), alt: photo.caption.presence || "Meetup photo", style: "border-radius: 4px;" %>
          <% end %>
        <% end %>
      </div>
    <% end %>
    <%= form.fields_for :meeting_photos, MeetingPhoto.new do |photo_form| %>
      <div style="display: inline-flex; align-items: center; gap: 0.5rem;">
        <%= photo_form.file_field :image, accept: "image/*", style: "font-size: 0.85rem;" %>
      </div>
    <% end %>
    <p class="muted" style="margin-top: 0.25rem; font-size: 0.8rem;">Attach a meetup photo (jpg, png). More photos can be added after saving.</p>
  </div>

  <div class="button-row">
    <%= form.submit submit_label %>
    <%= link_to "Cancel", meeting.persisted? ? admin_meeting_path(meeting) : admin_meetings_path, class: "button-link secondary" %>
  </div>
<% end %>
