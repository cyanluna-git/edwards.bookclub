<section class="hero">
  <p class="eyebrow">Meetup Hub</p>
  <h1><%= @meeting.title %></h1>
  <p class="hero-copy">
    One place to maintain attendance, reserve exceptions, review notes, and photo references for this meetup.
  </p>
</section>

<section class="detail-grid">
  <article class="panel stack">
    <div class="section-title">
      <div>
        <h2>Meetup summary</h2>
        <p class="muted"><%= @meeting.location.presence || "No location recorded" %></p>
      </div>
      <div class="button-row">
        <%= link_to "Edit details", edit_admin_meeting_path(@meeting), class: "button-link" %>
        <%= button_to "Delete meetup", admin_meeting_path(@meeting), method: :delete, class: "danger" %>
      </div>
    </div>

    <div class="meta-list">
      <div><span>Date and time</span><span><%= l(@meeting.meeting_at, format: :long) %></span></div>
      <div><span>Fiscal period</span><span><%= @meeting.fiscal_period&.name || "None" %></span></div>
      <div><span>Default reserve behavior</span><span><%= @meeting.reserve_exempt_default? ? "Exempt by default" : "Reserve applies by default" %></span></div>
      <div><span>Created by</span><span><%= @meeting.created_by&.email || "Unknown" %></span></div>
    </div>

    <% if @meeting.description.present? %>
      <div class="field-stack">
        <label>Description</label>
        <div class="panel"><%= simple_format(@meeting.description) %></div>
      </div>
    <% end %>

    <div class="field-stack">
      <label>Review notes</label>
      <%= form_with model: [:admin, @meeting], local: true do |form| %>
        <%= form.text_area :review, placeholder: "Capture 후기, follow-ups, and meetup notes here." %>
        <div class="button-row">
          <%= form.submit "Save review" %>
        </div>
      <% end %>
    </div>

    <div class="field-stack">
      <label>Photos (<%= @photos.size %>)</label>
      <% if @photos.any? %>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;">
          <% @photos.each do |photo| %>
            <div style="position: relative;">
              <% if photo.image.attached? %>
                <%= image_tag url_for(photo.image), alt: photo.caption.presence || "Meetup photo", style: "border-radius: 4px; object-fit: cover; width: 120px; height: 90px;" %>
              <% elsif photo.source_url.present? %>
                <div style="width: 120px; height: 80px; background: var(--muted-bg, #eee); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; color: var(--muted-text, #888);">URL</div>
              <% end %>
              <%= button_to "×", admin_meeting_photo_path(@meeting, photo), method: :delete, class: "danger", style: "position: absolute; top: -4px; right: -4px; min-width: 0; padding: 0 0.35rem; font-size: 0.75rem; line-height: 1.4;" %>
            </div>
          <% end %>
        </div>
      <% end %>
      <%= form_with model: [:admin, @meeting, @photo], url: admin_meeting_photos_path(@meeting), local: true, multipart: true, style: "display: inline-flex; align-items: center; gap: 0.5rem;" do |form| %>
        <%= form.file_field :image, accept: "image/*", style: "font-size: 0.85rem;" %>
        <%= form.submit "Upload photo", class: "button-link secondary", style: "white-space: nowrap;" %>
      <% end %>
    </div>
  </article>

  <aside class="panel stack">
    <h2>Snapshot</h2>
    <div class="stat-list">
      <div><span>Attendees</span><strong><%= @attendances.size %></strong></div>
      <div><span>Reserve exempt</span><strong><%= @attendances.count(&:reserve_exempt?) %></strong></div>
      <div><span>Attendance reserve</span><strong><%= number_to_currency(@attendances.sum { |attendance| attendance.effective_awarded_points }, unit: "₩", precision: 0) %></strong></div>
      <div><span>Photo records</span><strong><%= @photos.size %></strong></div>
    </div>
    <div class="button-row">
      <%= link_to "Back to meetups", admin_meetings_path, class: "button-link secondary" %>
    </div>
  </aside>
</section>

<section class="panel stack">
  <div class="section-title">
    <h2>Attendance (<%= @attendances.size %>)</h2>
  </div>

  <%= form_with model: [:admin, @meeting, @attendance], url: admin_meeting_attendances_path(@meeting), local: true, style: "display: flex; align-items: end; gap: 0.5rem; margin-bottom: 1rem;" do |form| %>
    <div class="field-stack" style="flex: 1;">
      <%= form.label :member_id, "Add member", style: "font-size: 0.8rem;" %>
      <%= form.select :member_id, options_for_select(@available_members.map { |member| ["#{member.english_name} · #{member.member_role}", member.id] }), { include_blank: "Select member" }, style: "font-size: 0.85rem; width: 100%;" %>
    </div>
    <%= form.submit "Add", style: "white-space: nowrap; padding: 0.45rem 1rem;" %>
  <% end %>

  <% if @attendances.any? %>
    <div class="stack" style="gap: 0.35rem;">
      <% @attendances.each do |attendance| %>
        <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.4rem 0.6rem; border: 1px solid var(--border, #ddd); border-radius: 6px; font-size: 0.85rem;">
          <strong style="min-width: 120px;"><%= attendance.member.english_name %></strong>
          <span class="muted" style="min-width: 60px; font-size: 0.75rem;"><%= attendance.member.member_role %></span>
          <span style="min-width: 70px; font-size: 0.8rem;"><%= number_to_currency(attendance.effective_awarded_points, unit: "₩", precision: 0) %></span>
          <span class="muted" style="font-size: 0.75rem;"><%= attendance.award_source_label %></span>
          <% if attendance.reserve_exempt? %>
            <span style="font-size: 0.7rem; background: #f0d36a; padding: 0.1rem 0.4rem; border-radius: 3px;">Exempt</span>
          <% end %>
          <% if attendance.note.present? %>
            <span class="muted" style="font-size: 0.75rem; flex: 1;"><%= attendance.note %></span>
          <% end %>
          <div style="margin-left: auto;">
            <%= button_to "×", admin_meeting_attendance_path(@meeting, attendance), method: :delete, class: "danger", style: "min-width: 0; padding: 0 0.4rem; font-size: 0.8rem; line-height: 1.5;" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <p class="muted">No attendees yet. Select a member above to add.</p>
    </div>
  <% end %>
</section>
