<section class="hero">
  <p class="eyebrow">Meetup Hub</p>
  <h1><%= @meeting.title %></h1>
  <p class="hero-copy">
    One place to maintain attendance, reserve exceptions, review notes, and photo references for this meetup.
  </p>
</section>

<section class="detail-grid">
  <article class="panel stack">
    <div class="section-title">
      <div>
        <h2>Meetup summary</h2>
        <p class="muted"><%= @meeting.location.presence || "No location recorded" %></p>
      </div>
      <div class="button-row">
        <%= link_to "Edit details", edit_admin_meeting_path(@meeting), class: "button-link" %>
        <%= button_to "Delete meetup", admin_meeting_path(@meeting), method: :delete, class: "danger" %>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: <%= @photos.any? ? 'auto 1fr' : '1fr' %>; gap: 1.25rem; align-items: start;">
      <% if @photos.any? %>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <% @photos.each_with_index do |photo, i| %>
            <% if photo.image.attached? %>
              <%= image_tag url_for(photo.image.variant(:medium)), alt: photo.caption.presence || "Meetup photo", style: "width: 280px; height: #{i == 0 ? 200 : 120}px; object-fit: cover; border-radius: 8px; display: block;" %>
            <% elsif photo.source_url.present? %>
              <%= image_tag photo.source_url, alt: photo.caption.presence || "Meetup photo", style: "width: 280px; height: #{i == 0 ? 200 : 120}px; object-fit: cover; border-radius: 8px; display: block;" %>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="stack">
        <div class="meta-list">
          <div><span>Date and time</span><span><%= l(@meeting.meeting_at, format: :long) %></span></div>
          <div><span>Fiscal period</span><span><%= @meeting.fiscal_period&.name || "None" %></span></div>
          <div><span>Attendees</span><strong><%= @attendances.size %></strong></div>
          <div><span>Attendance reserve</span><strong><%= number_to_currency(@attendances.sum { |a| a.effective_awarded_points }, unit: "₩", precision: 0) %></strong></div>
          <div><span>Reserve exempt</span><strong><%= @attendances.count(&:reserve_exempt?) %></strong></div>
          <div><span>Photos</span><strong><%= @photos.size %></strong></div>
        </div>

        <% if @meeting.description.present? %>
          <div class="field-stack">
            <label>Description</label>
            <div class="panel"><%= simple_format(@meeting.description) %></div>
          </div>
        <% end %>

        <% if @meeting.review.present? %>
          <div class="field-stack">
            <label>Review</label>
            <div style="font-size: 0.9rem; color: var(--ink, #333); padding: 0.5rem 0.75rem; background: var(--muted-bg, #f5f3ee); border-radius: 6px;">
              <%= simple_format(@meeting.review) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </article>

  <aside class="panel stack">
    <div class="section-title">
      <h2>Attendance (<%= @attendances.size %>)</h2>
    </div>

    <%= form_with model: [:admin, @meeting, @attendance], url: admin_meeting_attendances_path(@meeting), local: true, style: "display: flex; align-items: end; gap: 0.5rem; margin-bottom: 0.75rem;" do |form| %>
      <div class="field-stack" style="flex: 1;">
        <%= form.select :member_id, options_for_select(@available_members.map { |member| ["#{member.english_name} · #{member.member_role}", member.id] }), { include_blank: "Select member" }, style: "font-size: 0.85rem; width: 100%;" %>
      </div>
      <%= form.submit "Add", style: "white-space: nowrap; padding: 0.4rem 0.75rem; font-size: 0.85rem;" %>
    <% end %>

    <% if @attendances.any? %>
      <div class="stack" style="gap: 0.3rem;">
        <% @attendances.each do |attendance| %>
          <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.3rem 0.5rem; border: 1px solid var(--border, #ddd); border-radius: 4px; font-size: 0.8rem;">
            <strong style="flex: 1;"><%= attendance.member.english_name %></strong>
            <span class="muted" style="font-size: 0.7rem;"><%= attendance.member.member_role %></span>
            <span style="font-size: 0.75rem;"><%= number_to_currency(attendance.effective_awarded_points, unit: "₩", precision: 0) %></span>
            <% if attendance.reserve_exempt? %>
              <span style="font-size: 0.65rem; background: #f0d36a; padding: 0.1rem 0.3rem; border-radius: 3px;">Exempt</span>
            <% end %>
            <%= button_to "×", admin_meeting_attendance_path(@meeting, attendance), method: :delete, class: "danger", style: "min-width: 0; padding: 0 0.3rem; font-size: 0.75rem; line-height: 1.4;" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="muted" style="font-size: 0.8rem;">No attendees yet.</p>
    <% end %>

    <div style="margin-top: auto; padding-top: 0.75rem;">
      <%= link_to "Back to meetups", admin_meetings_path, class: "button-link secondary", style: "font-size: 0.8rem;" %>
    </div>
  </aside>
</section>
