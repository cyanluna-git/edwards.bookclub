<section class="hero">
  <p class="eyebrow">Admin Settings</p>
  <h1>Reserve policies</h1>
  <p class="hero-copy">Manage attendance-point rules by role and effective dates.</p>
</section>

<section class="panel stack">
  <div class="section-title">
    <div>
      <h2>Policies</h2>
      <p class="muted">Overlapping effective windows for the same role are blocked.</p>
    </div>
    <div class="button-row">
      <%= link_to "Fiscal periods", admin_fiscal_periods_path, class: "button-link secondary" %>
      <%= link_to "Office assignments", admin_office_assignments_path, class: "button-link secondary" %>
      <%= link_to "New reserve policy", new_admin_reserve_policy_path, class: "button-link" %>
    </div>
  </div>

  <% if @reserve_policies.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Role</th>
          <th>Points</th>
          <th>Effective window</th>
        </tr>
      </thead>
      <tbody>
        <% @reserve_policies.each do |policy| %>
          <tr>
            <td><strong><%= link_to policy.member_role, admin_reserve_policy_path(policy) %></strong></td>
            <td><%= policy.attendance_points %></td>
            <td><%= "#{policy.effective_from} to #{policy.effective_to || 'open-ended'}" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <h3>No reserve policies yet.</h3>
      <p>Create policies before relying on reserve calculations.</p>
    </div>
  <% end %>
</section>
